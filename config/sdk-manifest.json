{
  "service": {
    "name": "justserpapi",
    "display_name": "JustSerpAPI",
    "description": "OpenAPI-first Python SDK release tooling for JustSerpAPI.",
    "default_server_url": "https://api.justserpapi.com"
  },
  "spec": {
    "path": "openapi/justserpapi.openapi.json",
    "baseline_path": "openapi/baseline/justserpapi.openapi.json",
    "source_url": "https://api.justserpapi.com/openapi.json"
  },
  "generator": {
    "version": "7.20.0",
    "cache_dir": ".cache/openapi-generator"
  },
  "release": {
    "generated_dir": ".generated"
  },
  "languages": {
    "python": {
      "generator": "python",
      "output_subdir": "python",
      "config_template": "config/generators/python.json",
      "overlay_dir": "overlays/python",
      "package": {
        "name": "justserpapi",
        "registry": "pypi"
      },
      "repo": {
        "name": "justserpapi-python",
        "remote": "git@github.com:justserpapi/justserpapi-python.git",
        "default_branch": "main"
      }
    }
  }
}
